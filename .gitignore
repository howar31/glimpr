# Generated plugin registrant — regenerated by `flutter pub get`/build from the
# resolved plugin set. Untracked because the official (Pro) build swaps in a
# private plugin via pubspec_overrides.yaml, which would otherwise rewrite this
# tracked file to register the private plugin (leaking its existence + breaking
# the OSS build). Keeping it generated-only means the swap never touches a tracked
# file. The free build regenerates it locally with the public plugin set.
macos/Flutter/GeneratedPluginRegistrant.swift

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
